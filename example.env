# Prefect Configuration
PREFECT_API_URL=
PREFECT_API_KEY=

# Database Configuration
# If using the internal MariaDB chart, these override values.yaml defaults/generation
# DATABASE_HOST=
# DATABASE_PORT=3306
# DATABASE_NAME=specify

# Master User (used for migrations and initial setup)
MASTER_NAME=bn_specify
MASTER_PASSWORD=password

# Application User (runtime access)
APP_USER_NAME=bn_specify
APP_USER_PASSWORD=password

# Security Keys
SECRET_KEY=change-me-in-production
WEB_ATTACHMENT_KEY=change-me

# Debug Mode
# DEBUG=False

# Oracle Database (Source) - Production
ORACLE_PROD_HOST=dbora-musit-prod03.uio.no
ORACLE_PROD_PORT=1553
ORACLE_PROD_SERVICE=MUSIT
ORACLE_PROD_USER=
ORACLE_PROD_PASSWORD=

# Oracle Database (Source) - Test
ORACLE_TEST_HOST=dbora-musit-utv03.uio.no
ORACLE_TEST_PORT=1553
ORACLE_TEST_SERVICE=MUSTST
ORACLE_TEST_USER=
ORACLE_TEST_PASSWORD=
# Oracle Schema Snapshot Export (S3/MinIO compatible)
S3_BUCKET=
S3_PREFIX=oracle-schema
S3_ENDPOINT_URL=
S3_REGION=us-east-1
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_FORCE_PATH_STYLE=true
# MinIO/proxy compatibility: false avoids x-amz-content-sha256 mismatch issues
S3_PAYLOAD_SIGNING_ENABLED=false

# Optional schema owner filter for snapshot flow (comma-separated)
# Defaults to ORACLE_PROD_USER when empty.
ORACLE_SCHEMA_OWNERS=

