# =============================================================================
#  example.env — template for the shared Kubernetes Secret
# =============================================================================
#
#  Create the secret and wire it up:
#
#    kubectl create secret generic my-specify-secret --from-env-file=.env
#
#  Then in your Helm values override:
#
#    secrets:
#      existingSecret: my-specify-secret
#    mariadb:
#      auth:
#        existingSecret: my-specify-secret
#
# =============================================================================


# -- Database (MariaDB) ------------------------------------------------------
#
# mariadb-root-password / mariadb-password are the fixed key names the Bitnami
# MariaDB subchart reads from the Secret.  DB_PASSWORD must be set to the SAME
# value as mariadb-password — one is read by MariaDB to create the account,
# the other is read by the Django app to connect.

mariadb-root-password=
mariadb-password=

DB_NAME=specify
DB_USER=bn_specify
DB_PASSWORD=
# DB_HOST=              # auto-set to <release>-mariadb when subchart is enabled
# DB_PORT=3306


# -- Specify7 App ------------------------------------------------------------

SECRET_KEY=
ATTACHMENT_KEY=
# DEBUG=false


# -- Prefect ------------------------------------------------------------------
# Only needed when connecting to an external Prefect Cloud instance.
# The in-cluster server auto-configures PREFECT_API_URL for the dev worker.

# PREFECT_API_URL=
# PREFECT_API_KEY=


# -- Oracle Source Databases (migration flows) --------------------------------

ORACLE_PROD_HOST=dbora-musit-prod03.uio.no
ORACLE_PROD_PORT=1553
ORACLE_PROD_SERVICE=MUSIT
ORACLE_PROD_USER=
ORACLE_PROD_PASSWORD=

ORACLE_TEST_HOST=dbora-musit-utv03.uio.no
ORACLE_TEST_PORT=1553
ORACLE_TEST_SERVICE=MUSTST
ORACLE_TEST_USER=
ORACLE_TEST_PASSWORD=

# Comma-separated schema owner filter; defaults to ORACLE_PROD_USER.
# ORACLE_SCHEMA_OWNERS=


# -- S3 / MinIO (migration flows) --------------------------------------------

S3_BUCKET=
# Schema snapshot / other flows that still use a long prefix
S3_PREFIX=oracle-schema
# Migration report JSON only (default: migration-reports/… — not under S3_PREFIX)
# S3_MIGRATION_REPORTS_PREFIX=migration-reports
S3_ENDPOINT_URL=
S3_REGION=us-east-1
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_FORCE_PATH_STYLE=true
S3_PAYLOAD_SIGNING_ENABLED=false
