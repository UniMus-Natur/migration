<viewset name="common" source="disk" level="Common" file="common/common.views.xml">
  <views>
    <view name="AbsoluteAge" objtitle="AbsoluteAge" class="edu.ku.brc.specify.datamodel.AbsoluteAge">
      <altviews>
        <altview name="AbsoluteAge View" viewdef="AbsoluteAge" mode="view" validated="false" />
        <altview name="AbsoluteAge Edit" viewdef="AbsoluteAge" mode="edit" default="true" validated="false" />
        <altview name="AbsoluteAge Table View" viewdef="AbsoluteAge Table" mode="view" validated="false" />
        <altview name="AbsoluteAge Table Edit" viewdef="AbsoluteAge Table" mode="edit" validated="false" />
      </altviews>
    </view>
  </views>
  <viewdefs>
    <viewdef name="AbsoluteAge" class="edu.ku.brc.specify.datamodel.AbsoluteAge" type="form" gettable="edu.ku.brc.af.ui.forms.DataGetterForObj" settable="edu.ku.brc.af.ui.forms.DataSetterForObj">
      <desc>The RelativeAge Table</desc>
      <enableRules />
      <columnDef>p,2px,p,2px,p,2px,p,2px,p,2px,p,p:g</columnDef>
      <rowDef auto="true" cell="p" sep="2px" />
      <rows>
        <row>
          <cell type="label" labelfor="ageType" />
          <cell type="field" id="ageType" uitype="combobox" name="ageType" />
          <cell type="label" label="Attachments" />
          <cell type="subview" id="attachments" viewname="ObjectAttachment" name="absoluteAgeAttachments" initialize="btn=true;align=left;verticalAlign=center" defaulttype="icon" />
        </row>
        <row>
          <cell type="label" labelfor="absoluteAge" />
          <cell type="field" id="absoluteAge" uitype="text" name="absoluteAge" />
          <cell type="label" labelfor="ageUncertainty" />
          <cell type="field" id="ageUncertainty" uitype="text" name="ageUncertainty" />
        </row>
        <row>
          <cell type="label" labelfor="datingMethod" />
          <cell type="field" id="datingMethod" uitype="combobox" name="datingMethod" />
          <cell type="label" labelfor="datingMethodRemarks" />
          <cell type="field" id="datingMethodRemarks" uitype="textareabrief" name="datingMethodRemarks" />
        </row>
        <row>
          <cell type="label" labelfor="remarks" />
          <cell type="field" id="remarks" uitype="textareabrief" rows="2" name="remarks" colspan="6" />
        </row>
      </rows>
    </viewdef>
    <viewdef name="AbsoluteAge Table" class="edu.ku.brc.specify.datamodel.AbsoluteAge" type="formtable" gettable="edu.ku.brc.af.ui.forms.DataGetterForObj" settable="edu.ku.brc.af.ui.forms.DataSetterForObj">
      <desc>The AbsoluteAge Table</desc>
      <definition>AbsoluteAge</definition>
    </viewdef>
  </viewdefs>
</viewset>