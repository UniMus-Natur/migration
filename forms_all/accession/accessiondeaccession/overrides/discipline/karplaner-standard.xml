<viewset name="Karplaner - standard" source="db" level="Discipline">
  <views>
    <view name="AccessionDeaccession" class="edu.ku.brc.specify.datamodel.Accession" busrules="edu.ku.brc.specify.datamodel.busrules.AccessionBusRules">
      <desc>The Accession form as seen in the Deaccession form.</desc>
      <altviews>
        <altview name="AccessionDeaccession View" viewdef="AccessionDeaccession" mode="view" />
        <altview name="AccessionDeaccession Table View" viewdef="AccessionDeaccession Table" mode="view" default="true" />
      </altviews>
    </view>
  </views>
  <viewdefs>
    <viewdef type="form" name="AccessionDeaccession" class="edu.ku.brc.specify.datamodel.Accession" gettable="edu.ku.brc.af.ui.forms.DataGetterForObj" settable="edu.ku.brc.af.ui.forms.DataSetterForObj">
      <desc>The Accession subform for the deaccession form.</desc>
      <enableRules />
      <columnDef>p,0px,190px,5px,130px,2px,141px,5px,110px,2px,140px,0px,15px,p:g</columnDef>
      <columnDef os="lnx">135px,2px,200px,5px,135px,2px,156px,5px,125px,2px,150px,0px,15px,p:g</columnDef>
      <columnDef os="mac">130px,2px,220px,5px,153px,2px,189px,5px,133px,2px,189px,0px,15px,p:g</columnDef>
      <columnDef os="exp">p,0px,p:g,5px:g,p,2px,p:g(2),5px:g,p,2px,p:g(2),0px,p,p:g</columnDef>
      <rowDef auto="true" cell="p" sep="1px" />
      <rows>
        <row>
          <cell type="label" labelfor="1" />
          <cell type="field" id="1" name="accessionNumber" uitype="formattedtext" />
          <cell type="label" labelfor="3" />
          <cell type="field" id="3" name="type" uitype="combobox" />
          <cell type="label" labelfor="2" />
          <cell type="field" id="2" name="status" uitype="combobox" />
        </row>
        <row>
          <cell type="label" labelfor="5" />
          <cell type="field" id="5" name="dateAccessioned" uitype="formattedtext" uifieldformatter="Date" default="today" />
        </row>
      </rows>
    </viewdef>
    <viewdef type="formtable" name="AccessionDeaccession Table" class="edu.ku.brc.specify.datamodel.Accession" gettable="edu.ku.brc.af.ui.forms.DataGetterForObj" settable="edu.ku.brc.af.ui.forms.DataSetterForObj">
      <desc>The Accession subform for the deaccession form.</desc>
      <definition>AccessionDeaccession</definition>
    </viewdef>
  </viewdefs>
</viewset>