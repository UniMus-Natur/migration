<viewset name="Karplaner - standard" source="db" level="Discipline">
  <views>
    <view name="AgreementAgent" objtitle="Agreement Agent" class="edu.ku.brc.specify.datamodel.AccessionAgent" busrules="edu.ku.brc.specify.datamodel.busrules.AccessionAgentBusRules">
      <desc>Subform within the Accession form.</desc>
      <altviews>
        <altview name="AgreementAgent View" viewdef="AgreementAgent" mode="view" />
        <altview name="AgreementAgent Edit" viewdef="AgreementAgent" mode="edit" default="true" />
      </altviews>
    </view>
  </views>
  <viewdefs>
    <viewdef name="AgreementAgent" class="edu.ku.brc.specify.datamodel.AccessionAgent" type="form" gettable="edu.ku.brc.af.ui.forms.DataGetterForObj" settable="edu.ku.brc.af.ui.forms.DataSetterForObj">
      <desc>The RA agent</desc>
      <enableRules />
      <columnDef>30px,2px,300px,5px,20px,2px,130px,345px,p:g</columnDef>
      <rowDef auto="true" cell="p" sep="2px" />
      <rows>
        <row>
          <cell type="label" labelfor="1" />
          <cell type="field" id="1" name="agent" uitype="querycbx" initialize="name=Agent;title=Agent" />
          <cell type="label" labelfor="2" />
          <cell type="field" id="2" name="role" uitype="combobox" />
        </row>
        <row>
          <cell type="label" labelfor="3" />
          <cell type="field" id="3" name="remarks" uitype="textareabrief" colspan="6" />
        </row>
      </rows>
    </viewdef>
  </viewdefs>
</viewset>