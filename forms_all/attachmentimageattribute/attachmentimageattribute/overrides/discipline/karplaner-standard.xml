<viewset name="Karplaner - standard" source="db" level="Discipline">
  <views>
    <view name="AttachmentImageAttribute" class="edu.ku.brc.specify.datamodel.AttachmentImageAttribute" resourcelabels="false">
      <desc>The Attachment Image Attribute View.</desc>
      <altviews>
        <altview name="AttachmentImageAttribute Form View" viewdef="AttachmentImageAttribute Form" label="Form" mode="view" default="true" />
        <altview name="AttachmentImageAttribute Form Edit" viewdef="AttachmentImageAttribute Form" label="Form" mode="edit" />
      </altviews>
    </view>
  </views>
  <viewdefs>
    <viewdef type="form" name="AttachmentImageAttribute Form" class="edu.ku.brc.specify.datamodel.AttachmentImageAttribute" gettable="edu.ku.brc.af.ui.forms.DataGetterForObj" settable="edu.ku.brc.af.ui.forms.DataSetterForObj" useresourcelabels="true">
      <desc>The Attachment Image Attribute form.</desc>
      <columnDef>p,5dlu,p:g</columnDef>
      <rowDef auto="true" cell="p" sep="2px" />
      <rows>
        <row>
          <cell type="label" labelfor="height" label="HEIGHT" />
          <cell type="field" id="height" name="height" uitype="text" />
        </row>
        <row>
          <cell type="label" labelfor="width" label="WIDTH" />
          <cell type="field" id="width" name="width" uitype="text" />
        </row>
        <row>
          <cell type="label" labelfor="resolution" label="RESOLUTION" />
          <cell type="field" id="resolution" name="resolution" uitype="text" />
        </row>
        <row>
          <cell type="label" labelfor="magnification" label="MAGNIFICATION" />
          <cell type="field" id="magnification" name="magnification" uitype="text" />
        </row>
        <row>
          <cell type="label" labelfor="creativeCommons" label="CREATIVE_COMMONS" />
          <cell type="field" id="creativeCommons" name="creativeCommons" uitype="text" />
        </row>
        <row>
          <cell type="label" labelfor="mbImageId" label="MBIMAGEID" />
          <cell type="field" id="mbImageId" name="mbImageId" uitype="text" />
        </row>
        <row>
          <cell type="label" labelfor="timeStampLastSend" label="TIMESTAMP_LAST_SEND" />
          <cell type="field" id="timeStampLastSend" name="timestampLastSend" uitype="text" readonly="true" uifieldformatter="Date" />
        </row>
        <row>
          <cell type="label" labelfor="timeStampLastUpdateCheck" label="TIMESTAMP_LAST_UPDATECHECK" />
          <cell type="field" id="timeStampLastUpdateCheck" name="timestampLastUpdateCheck" uitype="text" readonly="true" uifieldformatter="Date" />
        </row>
      </rows>
    </viewdef>
  </viewdefs>
</viewset>