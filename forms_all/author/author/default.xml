<viewset name="Global" source="disk" level="Backstop" file="backstop/global.views.xml">
  <views>
    <view name="Author" class="edu.ku.brc.specify.datamodel.Author" resourcelabels="false" busrules="edu.ku.brc.specify.datamodel.busrules.AuthorBusRules">
      <desc>The Author subform for Reference Work form.</desc>
      <altviews>
        <altview name="Author View" viewdef="Author" mode="view" default="true" />
        <altview name="Author Edit" viewdef="Author" mode="edit" />
      </altviews>
    </view>
  </views>
  <viewdefs>
    <viewdef type="form" name="Author" class="edu.ku.brc.specify.datamodel.Author" gettable="edu.ku.brc.af.ui.forms.DataGetterForObj" settable="edu.ku.brc.af.ui.forms.DataSetterForObj">
      <desc>Author subform for Reference Work</desc>
      <columnDef>100px,2px,240px,485px,p:g</columnDef>
      <columnDef os="lnx">115px,2px,265px,535px,p:g</columnDef>
      <columnDef os="mac">130px,2px,250px,650px,p:g</columnDef>
      <columnDef os="exp">p,2px,p,p:g</columnDef>
      <rowDef auto="true" sep="2px" cell="p" />
      <rows>
        <row>
          <cell type="label" labelfor="3" />
          <cell type="field" id="3" name="agent" uitype="querycbx" initialize="name=Agent;title=Agent" />
        </row>
        <row>
          <cell type="label" labelfor="2" />
          <cell type="field" id="2" name="remarks" uitype="textareabrief" rows="2" colspan="2" />
        </row>
      </rows>
    </viewdef>
  </viewdefs>
</viewset>