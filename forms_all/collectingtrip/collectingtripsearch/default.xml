<viewset name="Search" source="disk" level="Backstop" file="backstop/search.views.xml">
  <views>
    <view name="CollectingTripSearch" class="edu.ku.brc.specify.datamodel.CollectingTrip" usedefbusrule="false" resourcelabels="false">
      <desc>The Collecting Trip Search Form</desc>
      <altviews>
        <altview name="CollectingTripSearch" viewdef="CollectingTripSearch" mode="edit" validated="true" default="true" />
      </altviews>
    </view>
  </views>
  <viewdefs>
    <viewdef type="form" name="CollectingTripSearch" class="edu.ku.brc.specify.datamodel.CollectingTrip" gettable="edu.ku.brc.af.ui.forms.DataGetterForHashMap" settable="edu.ku.brc.af.ui.forms.DataSetterForHashMap">
      <desc>The Collecting Trip Search Form</desc>
      <enableRules />
      <columnDef>p,3dlu,p</columnDef>
      <rowDef>p,2dlu,p,2dlu,p</rowDef>
      <rows>
        <row>
          <cell type="separator" label="Collecting Trip" colspan="3" />
        </row>
        <row>
          <cell type="label" labelfor="1" />
          <cell type="field" id="1" name="CollectingTripName" uitype="text" />
        </row>
        <row>
          <cell type="label" labelfor="2" />
          <cell type="field" id="2" name="StartDate" uitype="formattedtext" uifieldformatter="SearchDate" initialize="ispartial=true;" />
        </row>
      </rows>
    </viewdef>
  </viewdefs>
</viewset>