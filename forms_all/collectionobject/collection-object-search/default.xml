<viewset name="common" source="disk" level="Common" file="common/common.views.xml">
  <views>
    <view name="Collection Object Search" class="edu.ku.brc.specify.datamodel.CollectionObject" busrules="edu.ku.brc.specify.datamodel.busrules.CollectionObjectBusRules">
      <desc>The Collection Object Search form.</desc>
      <altviews>
        <altview name="Collection Object Search" viewdef="Collection Object Search" label="Search" mode="search" default="true" />
      </altviews>
    </view>
  </views>
  <viewdefs>
    <viewdef type="form" name="Collection Object Search" class="java.util.Hashtable" gettable="edu.ku.brc.af.ui.forms.DataGetterForHashMap" settable="edu.ku.brc.af.ui.forms.DataSetterForHashMap">
      <desc>The Collection Object form.</desc>
      <enableRules />
      <columnDef>120px,2px,p,2px,120px,2px,p,2px,60px,2px,p,p:g</columnDef>
      <rowDef auto="true" cell="p" sep="2dlu" />
      <rows>
        <row>
          <cell type="label" labelfor="1" />
          <cell type="field" id="1" name="catalogNumber" uitype="text" />
          <cell type="label" labelfor="2" />
          <cell type="field" id="2" name="collection_collectionName" uitype="text" />
        </row>
        <row>
          <cell type="label" labelfor="3" />
          <cell type="field" id="3" name="accession_number" uitype="formattedtext" uifieldformatter="AccessionNumber" />
          <cell type="label" labelfor="4" />
          <cell type="field" id="4" name="cataloger" uitype="text" />
          <cell type="label" labelfor="5" />
          <cell type="field" id="5" uitype="plugin" name="this" initialize="name=PartialDateUI;df=catalogedDate;tp=catalogedDatePrecision" uifieldformatter="Date" />
        </row>
      </rows>
    </viewdef>
  </viewdefs>
</viewset>