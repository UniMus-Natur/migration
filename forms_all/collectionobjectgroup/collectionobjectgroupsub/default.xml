<viewset name="common" source="disk" level="Common" file="common/common.views.xml">
  <views>
    <view name="CollectionObjectGroupSub" class="edu.ku.brc.specify.datamodel.CollectionObjectGroup" busrules="edu.ku.brc.specify.datamodel.busrules.CollectionObjectGroupBusRules" resourcelabels="false">
      <desc>The Collection Object Group form.</desc>
      <altviews>
        <altview name="CollectionObjectGroup View" viewdef="CollectionObjectGroupSub" mode="view" default="true" />
        <altview name="CollectionObjectGroup Edit" viewdef="CollectionObjectGroupSub" mode="edit" />
      </altviews>
    </view>
  </views>
  <viewdefs>
    <viewdef name="CollectionObjectGroupSub" class="edu.ku.brc.specify.datamodel.CollectionObjectGroup" type="form" gettable="edu.ku.brc.af.ui.forms.DataGetterForObj" settable="edu.ku.brc.af.ui.forms.DataSetterForObj">
      <desc>Collection Object Group Subform</desc>
      <enableRules />
      <columnDef>50px,2px,150px,5px,50px,2px,150px,5px,50px,2px,p:g</columnDef>
      <rowDef auto="true" cell="p" sep="2px" />
      <rows>
        <row>
          <cell type="label" labelfor="name" />
          <cell type="field" id="name" name="name" uitype="text" />
          <cell type="label" labelfor="cogType" />
          <cell type="field" id="cogType" name="cogType" uitype="combobox" picklist="COGTypes" />
          <cell type="subview" id="cojo" name="children" uitype="subview" initialize="btn=true" />
        </row>
      </rows>
    </viewdef>
  </viewdefs>
</viewset>