<viewset name="SystemSetup" source="disk" level="Backstop" file="backstop/system.views.xml">
  <views>
    <view name="DataType" class="edu.ku.brc.specify.datamodel.DataType" busrules="edu.ku.brc.specify.datamodel.busrules.DataTypeBusRules" resourcelabels="false">
      <desc>The DataType Object form.</desc>
      <altviews>
        <altview name="DataType Edit View" viewdef="DataType" mode="view" validated="false" />
        <altview name="DataType Edit" viewdef="DataType" mode="edit" validated="true" default="true" />
      </altviews>
    </view>
  </views>
  <viewdefs>
    <viewdef type="form" name="DataType" class="edu.ku.brc.specify.datamodel.DataType" gettable="edu.ku.brc.af.ui.forms.DataGetterForObj" settable="edu.ku.brc.af.ui.forms.DataSetterForObj">
      <desc>DataType Data Entry Form</desc>
      <columnDef>p,3dlu,p,2dlu,p:g</columnDef>
      <rowDef auto="true" cell="p" sep="2dlu" />
      <rows>
        <row>
          <cell type="separator" label="Data Type" colspan="5" />
        </row>
        <row>
          <cell type="label" labelfor="1" label="Name" />
          <cell type="field" id="1" name="name" uitype="text" isrequired="true" />
        </row>
      </rows>
    </viewdef>
  </viewdefs>
</viewset>