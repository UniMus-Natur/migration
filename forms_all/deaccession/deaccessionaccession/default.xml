<viewset name="common" source="disk" level="Common" file="common/common.views.xml">
  <views>
    <view name="DeaccessionAccession" class="edu.ku.brc.specify.datamodel.Deaccession">
      <desc>The Deaccession form from inside the Accession form.</desc>
      <altviews>
        <altview name="DeaccessionAccession View" viewdef="DeaccessionAccession" mode="view" />
        <altview name="DeaccessionAccession Table View" viewdef="DeaccessionAccession Table" mode="view" default="true" />
      </altviews>
    </view>
  </views>
  <viewdefs>
    <viewdef type="form" name="DeaccessionAccession" class="edu.ku.brc.specify.datamodel.Deaccession" gettable="edu.ku.brc.af.ui.forms.DataGetterForObj" settable="edu.ku.brc.af.ui.forms.DataSetterForObj">
      <desc>The Deaccession form from inside the Accession form.</desc>
      <enableRules />
      <columnDef>100px,2px,110px,5px,130px,2px,114px,5px,60px,2px,120px,5px,70px,2px,100px,p:g</columnDef>
      <columnDef os="lnx">135px,2px,120px,5px,135px,2px,123px,5px,75px,2px,133px,5px,63px,2px,100px,p:g</columnDef>
      <columnDef os="mac">130px,2px,140px,5px,153px,2px,149px,5px,93px,2px,159px,5px,73px,2px,110px,p:g</columnDef>
      <columnDef os="exp">p,2px,p:g,5px:g,p,2px,p:g(2),5px:g,p,2px,p:g(2),5px:g,p,2px,p:g(2),p:g</columnDef>
      <rowDef auto="true" cell="p" sep="2px" />
      <rows>
        <row>
          <cell type="label" labelfor="1" />
          <cell type="field" id="1" name="deaccessionNumber" uitype="formattedtext" />
          <cell type="label" labelfor="5" />
          <cell type="field" id="5" name="deaccessionDate" uitype="formattedtext" uifieldformatter="Date" default="today" />
          <cell type="label" labelfor="ldtype" />
          <cell type="field" id="ldtype" name="type" uitype="combobox" />
          <cell type="label" labelfor="st" />
          <cell type="field" id="st" name="status" uitype="combobox" />
        </row>
        <row>
          <cell type="label" labelfor="rem" />
          <cell type="field" id="rem" name="remarks" uitype="textareabrief" rows="2" colspan="14" />
        </row>
      </rows>
    </viewdef>
    <viewdef type="formtable" name="DeaccessionAccession Table" class="edu.ku.brc.specify.datamodel.Deaccession" gettable="edu.ku.brc.af.ui.forms.DataGetterForObj" settable="edu.ku.brc.af.ui.forms.DataSetterForObj">
      <desc>Horizontal interpretation of the Deaccession form from inside the Accession form.</desc>
      <definition>DeaccessionAccession</definition>
    </viewdef>
  </viewdefs>
</viewset>