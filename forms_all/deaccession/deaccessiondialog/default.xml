<viewset name="common" source="disk" level="Common" file="common/common.views.xml">
  <views>
    <view name="DeaccessionDialog" class="edu.ku.brc.specify.datamodel.Deaccession">
      <desc>The Deaccession pop up form.</desc>
      <altviews>
        <altview name="DeaccessionDialog View" viewdef="DeaccessionDialog" mode="view" default="true" />
        <altview name="DeaccessionDialog Edit" viewdef="DeaccessionDialog" mode="edit" />
      </altviews>
    </view>
  </views>
  <viewdefs>
    <viewdef type="form" name="DeaccessionDialog" class="edu.ku.brc.specify.datamodel.Deaccession" gettable="edu.ku.brc.af.ui.forms.DataGetterForObj" settable="edu.ku.brc.af.ui.forms.DataSetterForObj">
      <desc>The Deaccession pop up form.</desc>
      <enableRules />
      <columnDef>100px,2px,110px,5px,120px,2px,114px,5px,55px,2px,140px,5px,65px,2px,100px,0px,15px,p:g</columnDef>
      <columnDef os="lnx">135px,2px,115px,5px,135px,2px,120px,5px,55px,2px,161px,5px,63px,2px,100px,0px,15px,p:g</columnDef>
      <columnDef os="mac">130px,2px,140px,5px,153px,2px,149px,5px,73px,2px,179px,5px,73px,2px,110px,0px,15px,p:g</columnDef>
      <columnDef os="exp">p,2px,p:g,5px:g,p,2px,p:g(2),5px:g,p,2px,p:g(2),5px:g,p,2px,p:g(2),0px,p,p:g</columnDef>
      <rowDef auto="true" cell="p" sep="2px" />
      <rows>
        <row>
          <cell type="label" labelfor="1" />
          <cell type="field" id="1" name="deaccessionNumber" uitype="text" />
          <cell type="label" labelfor="5" />
          <cell type="field" id="5" name="deaccessionDate" uitype="formattedtext" uifieldformatter="Date" default="today" />
          <cell type="label" labelfor="ldtype" />
          <cell type="field" id="ldtype" name="type" uitype="combobox" />
          <cell type="label" labelfor="st" />
          <cell type="field" id="st" name="status" uitype="combobox" />
        </row>
        <row>
          <cell type="label" label="Total Preps:" initialize="align=right" />
          <cell type="field" id="ti" name="totalPreps" uitype="text" readonly="true" />
          <cell type="label" label="Total Items:" initialize="align=right" />
          <cell type="field" id="tq" name="totalItems" uitype="text" readonly="true" />
        </row>
        <row>
          <cell type="subview" viewname="DeaccessionAgent" id="8" name="deaccessionAgents" desc="Agents" colspan="17" rows="2" />
        </row>
        <row>
          <cell type="label" labelfor="rem" />
          <cell type="field" id="rem" name="remarks" uitype="textareabrief" rows="2" colspan="13" />
        </row>
        <row>
          <cell type="subview" viewname="AccessionDeaccession" id="idaccessionco" name="accessions" colspan="17" readonly="true" />
        </row>
        <row>
          <cell type="separator" label="" colspan="17" />
        </row>
        <row>
          <cell type="subview" id="attachments" viewname="ObjectAttachment" name="deaccessionAttachments" colspan="3" initialize="btn=true;icon=DeaccessionAttachment;hc=xxx" />
          <cell type="label" labelfor="10" />
          <cell type="field" id="10" name="modifiedByAgent" uitype="label" readonly="true" uifieldformatter="Agent" />
          <cell type="label" labelfor="11" colspan="3" />
          <cell type="field" id="11" name="timestampModified" uitype="label" readonly="true" colspan="3" />
        </row>
      </rows>
    </viewdef>
  </viewdefs>
</viewset>