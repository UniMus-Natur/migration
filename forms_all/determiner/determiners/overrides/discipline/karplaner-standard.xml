        <row>
          <cell type="label" labelfor="7" />
          <cell type="field" id="7" name="remarks" uitype="text" colspan="3" />
        </row>
      </rows>
    </viewdef>
    <viewdef type="formtable" name="Determiners Table" class="edu.ku.brc.specify.datamodel.Determiner" gettable="edu.ku.brc.af.ui.forms.DataGetterForObj" settable="edu.ku.brc.af.ui.forms.DataSetterForObj">
