<viewset name="common" source="disk" level="Common" file="common/common.views.xml">
  <views>
    <view name="Disposal" class="edu.ku.brc.specify.datamodel.Disposal">
      <desc>The Disposal form.</desc>
      <altviews>
        <altview name="Disposal View" viewdef="Disposal" mode="view" default="true" />
        <altview name="Disposal Edit" viewdef="Disposal" mode="edit" />
      </altviews>
    </view>
  </views>
  <viewdefs>
    <viewdef type="form" name="Disposal" class="edu.ku.brc.specify.datamodel.Disposal" gettable="edu.ku.brc.af.ui.forms.DataGetterForObj" settable="edu.ku.brc.af.ui.forms.DataSetterForObj">
      <desc>The Disposal form.</desc>
      <enableRules />
      <columnDef>105px,2px,130px,5px,151px,2px,130px,5px,90px,2px,210px,0px,15px,p:g</columnDef>
      <columnDef os="lnx">130px,2px,150px,5px,155px,2px,170px,5px,95px,2px,216px,0px,15px,p:g</columnDef>
      <columnDef os="mac">130px,2px,165px,5px,175px,2px,190px,5px,111px,2px,245px,0px,15px,p:g</columnDef>
      <columnDef os="exp">p,2px,p:g(2),5px:g,p,2px,p:g,5px:g,p,2px,p:g(2),0px,p,p:g</columnDef>
      <rowDef auto="true" cell="p" sep="2px" />
      <rows>
        <row>
          <cell type="label" labelfor="1" />
          <cell type="field" id="1" name="disposalNumber" uitype="formattedtext" />
          <cell type="label" labelfor="5" />
          <cell type="field" id="5" name="disposalDate" uitype="formattedtext" uifieldformatter="Date" default="today" />
          <cell type="label" labelfor="2" />
          <cell type="field" id="2" name="type" uitype="combobox" />
        </row>
        <row>
          <cell type="label" label="Total Preps:" initialize="align=right" />
          <cell type="field" id="ti" name="totalPreps" uitype="text" readonly="true" />
          <cell type="label" label="Total Items:" initialize="align=right" />
          <cell type="field" id="tq" name="totalItems" uitype="text" readonly="true" />
        </row>
        <row>
          <cell type="label" labelfor="ldqx" />
          <cell type="field" id="ldqx" name="deaccession" uitype="querycbx" initialize="name=Deaccession;title=Deaccession" colspan="9" />
        </row>
        <row />
        <row>
          <cell type="subview" viewname="DisposalAgent" id="8" name="disposalAgents" desc="Agents" colspan="13" rows="3" />
        </row>
        <row>
          <cell type="subview" viewname="DisposalPreparation" id="4" name="disposalPreparations" defaulttype="table" colspan="13" />
        </row>
        <row>
          <cell type="separator" label="" colspan="13" />
        </row>
        <row>
          <cell type="subview" id="attachments" viewname="ObjectAttachment" name="disposalAttachments" colspan="3" initialize="btn=true;icon=DisposalAttachment;hc=xxx" />
          <cell type="label" labelfor="10" />
          <cell type="field" id="10" name="modifiedByAgent" uitype="label" readonly="true" uifieldformatter="Agent" />
          <cell type="label" labelfor="11" />
          <cell type="field" id="11" name="timestampModified" uitype="label" readonly="true" colspan="2" />
        </row>
      </rows>
    </viewdef>
  </viewdefs>
</viewset>