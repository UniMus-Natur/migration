    <viewdef type="formtable" name="DisposalPreparation Table" class="edu.ku.brc.specify.datamodel.DisposalPreparation" gettable="edu.ku.brc.af.ui.forms.DataGetterForObj" settable="edu.ku.brc.af.ui.forms.DataSetterForObj">
      <desc>The Agent subform for the disposal form.</desc>
      <definition>DisposalPreparation</definition>
