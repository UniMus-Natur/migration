        <altview name="DisposalPreparation Table Edit" viewdef="DisposalPreparation Table" mode="edit" />
      </altviews>
    </view>
  </views>
  <viewdefs>
    <viewdef type="form" name="DisposalPreparation" class="edu.ku.brc.specify.datamodel.DisposalPreparation" gettable="edu.ku.brc.af.ui.forms.DataGetterForObj" settable="edu.ku.brc.af.ui.forms.DataSetterForObj">
      <desc>The DisposalPreparation subform for Disposal form.</desc>
      <enableRules />
      <columnDef>105px,2px,120px,5px,80px,2px,120px,5px,120px,2px,130px,5px,73px,2px,56px,p:g</columnDef>
      <columnDef os="lnx">130px,2px,112px,5px,95px,2px,90px,5px,130px,2px,158px,5px,53px,2px,81px,p:g</columnDef>
      <columnDef os="mac">130px,2px,141px,5px,110px,2px,145px,5px,153px,2px,175px,5px,90px,2px,75px,p:g</columnDef>
      <columnDef os="exp">p,2px,p:g,5px:g,p,2px,p:g,5px:g,p,2px,p:g,5px,p:g,2px,p:g</columnDef>
      <rowDef auto="true" cell="p" sep="2px" />
