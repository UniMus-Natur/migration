<viewset name="Karplaner - standard" source="db" level="Discipline">
  <views>
    <view name="DNAPrimer" objtitle="DNA Primer" class="edu.ku.brc.specify.datamodel.DNAPrimer" isinternal="false">
      <desc>DNA Sequencing form.</desc>
      <altviews>
        <altview name="DNAPrimer View" viewdef="DNAPrimer" mode="view" />
        <altview name="DNAPrimer Edit" viewdef="DNAPrimer" mode="edit" default="true" />
      </altviews>
    </view>
  </views>
  <viewdefs>
    <viewdef name="DNAPrimer" type="form" class="edu.ku.brc.specify.datamodel.DNAPrimer" gettable="edu.ku.brc.af.ui.forms.DataGetterForObj" settable="edu.ku.brc.af.ui.forms.DataSetterForObj">
      <desc>DNA Sequence Form</desc>
      <enableRules />
      <columnDef>140px,2px,121px,5px,128px,2px,120px,5px,120px,2px,120px,0px,15px,p:g</columnDef>
      <columnDef os="lnx">157px,2px,150px,2px,143px,2px,150px,2px,153px,5px,151px,0px,15px,p:g</columnDef>
      <columnDef os="mac">162px,2px,176px,2px,158px,2px,175px,2px,173px,5px,175px,0px,15px,p:g</columnDef>
      <columnDef os="exp">p,2px,p:g,2px,p:g(2),5px,p:g,2px,p:g(2),5px:g,p,2px,p:g,0px,p,p:g</columnDef>
      <rowDef auto="true" cell="p" sep="2px" />
      <rows>
        <row>
          <cell type="label" labelfor="1" />
          <cell type="field" id="1" name="primerDesignator" uitype="text" />
          <cell type="label" labelfor="2" />
          <cell type="field" id="2" name="primerNameForward" uitype="text" />
          <cell type="label" labelfor="3" />
          <cell type="field" id="3" name="primerNameReverse" uitype="text" />
        </row>
        <row>
          <cell type="label" labelfor="4" />
          <cell type="field" id="4" name="primerSequenceForward" uitype="text" colspan="3" />
          <cell type="label" labelfor="5" />
          <cell type="field" id="5" name="primerSequenceReverse" uitype="text" colspan="3" />
        </row>
        <row>
          <cell type="label" labelfor="6" />
          <cell type="field" id="6" name="primerReferenceLinkForward" uitype="text" colspan="9" />
        </row>
        <row>
          <cell type="label" labelfor="7" />
          <cell type="field" id="7" name="primerReferenceLinkReverse" uitype="text" colspan="9" />
        </row>
        <row>
          <cell type="label" labelfor="8" />
          <cell type="field" id="8" name="primerReferenceCitationForward" uitype="text" colspan="9" />
        </row>
        <row>
          <cell type="label" labelfor="9" />
          <cell type="field" id="9" name="primerReferenceCitationReverse" uitype="text" colspan="9" />
        </row>
        <row>
          <cell type="label" labelfor="41" />
          <cell type="field" id="41" name="remarks" uitype="textareabrief" rows="2" colspan="9" />
        </row>
      </rows>
    </viewdef>
  </viewdefs>
</viewset>