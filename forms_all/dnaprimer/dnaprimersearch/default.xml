<viewset name="Search" source="disk" level="Backstop" file="backstop/search.views.xml">
  <views>
    <view name="DNAPrimerSearch" class="edu.ku.brc.specify.datamodel.DNAPrimer" usedefbusrule="false" resourcelabels="false">
      <desc>The Division Search Form</desc>
      <altviews>
        <altview name="DNAPrimerSearch" viewdef="DNAPrimerSearch" mode="edit" validated="true" default="true" />
      </altviews>
    </view>
  </views>
  <viewdefs>
    <viewdef type="form" name="DNAPrimerSearch" class="edu.ku.brc.specify.datamodel.DNAPrimer" gettable="edu.ku.brc.af.ui.forms.DataGetterForHashMap" settable="edu.ku.brc.af.ui.forms.DataSetterForHashMap">
      <desc>The Division Search Form</desc>
      <enableRules />
      <columnDef>p,2px,p</columnDef>
      <rowDef>p,2dlu,p</rowDef>
      <rows>
        <row>
          <cell type="separator" label="DNA Primer" colspan="3" />
        </row>
        <row>
          <cell type="label" labelfor="1" />
          <cell type="field" id="1" name="primerDesignator" uitype="text" />
        </row>
      </rows>
    </viewdef>
  </viewdefs>
</viewset>