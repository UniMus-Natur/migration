<viewset name="common" source="disk" level="Common" file="common/common.views.xml">
  <views>
    <view name="DNASequenceSubView" objtitle="DNA Sequence" class="edu.ku.brc.specify.datamodel.DNASequence" busrules="edu.ku.brc.specify.datamodel.busrules.DNASequenceBusRules">
      <desc>DNA Sequencing form.</desc>
      <altviews>
        <altview name="DNASequence View" viewdef="DNASequenceSubView" mode="view" />
        <altview name="DNASequence Edit" viewdef="DNASequenceSubView" mode="edit" default="true" />
      </altviews>
    </view>
  </views>
  <viewdefs>
    <viewdef name="DNASequenceSubView" type="form" class="edu.ku.brc.specify.datamodel.DNASequence" gettable="edu.ku.brc.af.ui.forms.DataGetterForObj" settable="edu.ku.brc.af.ui.forms.DataSetterForObj">
      <desc>DNA Sequence Form</desc>
      <enableRules />
      <columnDef>100px,2px,76px,2px,100px,5px,108px,2px,130px,5px,100px,2px,195px,0px,10px,p:g</columnDef>
      <columnDef os="lnx">115px,2px,66px,2px,113px,2px,140px,2px,133px,5px,125px,2px,210px,0px,10px,p:g</columnDef>
      <columnDef os="mac">130px,2px,76px,2px,123px,2px,160px,2px,153px,5px,145px,2px,230px,0px,10px,p:g</columnDef>
      <columnDef os="exp">p,2px,p:g,2px,p:g(2),5px,p:g,2px,p:g(2),5px:g,p,2px,p:g,0px</columnDef>
      <rowDef auto="true" cell="p" sep="2px" />
      <rows>
        <row>
          <cell type="label" labelfor="11" />
          <cell type="field" id="11" name="boldBarcodeId" uitype="text" colspan="3" />
          <cell type="label" labelfor="3" />
          <cell type="field" id="3" name="boldLastUpdateDate" uitype="formattedtext" uifieldformatter="Date" default="Today" />
          <cell type="label" labelfor="bsid" />
          <cell type="field" id="bsid" name="boldSampleID" uitype="text" />
        </row>
        <row>
          <cell type="label" labelfor="7" />
          <cell type="field" id="7" name="collectionObject" uitype="querycbx" initialize="name=CollectionObject;editbtn=false;newbtn=false" colspan="3" />
          <cell type="label" labelfor="2" />
          <cell type="field" id="2" name="moleculeType" uitype="text" />
          <cell type="label" labelfor="22" />
          <cell type="field" id="22" name="pcrPerson" uitype="querycbx" initialize="name=Agent" />
        </row>
        <row>
          <cell type="separator" label="Nucleotide Sequence" colspan="8" />
        </row>
        <row>
          <cell type="panel" id="16" name="outerPanel" coldef="150px,2px,p" rowdef="p,2px,p,2px,p,2px,p,2px,p,2px,p,2px" colspan="3">
            <rows>
              <row>
                <cell type="label" label="Total Residues:" initialize="align=right" />
                <cell type="field" id="residues" name="totalResidues" uitype="text" readonly="true" />
              </row>
              <row>
                <cell type="label" label="Comp A:" initialize="align=right;fg=0,190,0" />
                <cell type="field" id="compA" name="compa" uitype="text" readonly="true" />
              </row>
              <row>
                <cell type="label" label="Comp G:" initialize="align=right" />
                <cell type="field" id="compG" name="compg" uitype="text" readonly="true" />
              </row>
              <row>
                <cell type="label" label="Comp C:" initialize="align=right;fg=0,0,190" />
                <cell type="field" id="compC" name="compc" uitype="text" readonly="true" />
              </row>
              <row>
                <cell type="label" label="Comp T:" initialize="align=right;fg=190,0,0" />
                <cell type="field" id="compT" name="compt" uitype="text" readonly="true" />
              </row>
              <row>
                <cell type="label" label="Ambiguous:" initialize="align=right" />
                <cell type="field" id="ambiguous" name="ambiguousResidues" uitype="text" readonly="true" />
              </row>
            </rows>
          </cell>
          <cell type="field" id="4" name="geneSequence" uitype="textarea" colspan="4" rows="8" />
        </row>
        <row>
          <cell type="subview" viewname="DNASequenceRun" id="21" name="dnaSequencingRuns" colspan="8" />
        </row>
      </rows>
    </viewdef>
  </viewdefs>
</viewset>