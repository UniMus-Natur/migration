<viewset name="Karplaner - standard" source="db" level="Discipline">
  <views>
    <view name="DNASequencingRun" objtitle="DNA Sequencing Run" class="edu.ku.brc.specify.datamodel.DNASequencingRun" busrules="edu.ku.brc.specify.datamodel.busrules.DNASequencingRunBusRules">
      <desc>DNA SequencingRun</desc>
      <altviews>
        <altview name="DNASequenceRun View" viewdef="DNASequenceRun" mode="view" />
        <altview name="DNASequenceRun Edit" viewdef="DNASequenceRun" mode="edit" default="true" />
      </altviews>
    </view>
  </views>
  <viewdefs>
    <viewdef name="DNASequenceRun" type="form" class="edu.ku.brc.specify.datamodel.DNASequencingRun" gettable="edu.ku.brc.af.ui.forms.DataGetterForObj" settable="edu.ku.brc.af.ui.forms.DataSetterForObj">
      <desc>DNA Sequenc</desc>
      <enableRules />
      <columnDef>105px,2px,145px,5px,150px,2px,143px,5px,125px,2px,136px,0px,p:g</columnDef>
      <columnDef os="lnx">115px,2px,157px,5px,168px,2px,165px,5px,150px,2px,138px,p:g</columnDef>
      <columnDef os="mac">130px,2px,177px,5px,178px,2px,185px,5px,180px,2px,158px,p:g</columnDef>
      <columnDef os="exp">p,2px,p:g(2),5px:g,p,2px,p:g(2),5px,p:g,2px,p:g(2)</columnDef>
      <rowDef auto="true" cell="p" sep="2px" />
      <rows>
        <row>
          <cell type="label" labelfor="3" />
          <cell type="field" id="3" name="sraRunID" uitype="text" />
          <cell type="label" labelfor="4" />
          <cell type="field" id="4" name="sraExperimentID" uitype="text" />
          <cell type="label" labelfor="5" />
          <cell type="field" id="5" name="sraSubmissionID" uitype="text" />
        </row>
        <row>
          <cell type="label" labelfor="1" />
          <cell type="field" id="1" name="runDate" uitype="formattedtext" uifieldformatter="Date" />
          <cell type="label" labelfor="15" />
          <cell type="field" id="15" name="runByAgent" uitype="querycbx" initialize="name=Agent;title=Agent" colspan="5" />
        </row>
        <row>
          <cell type="label" labelfor="2" />
          <cell type="field" id="2" name="dnaPrimer" uitype="querycbx" initialize="name=DNAPrimer;title=DNAPrimer" isrequired="false" colspan="3" />
          <cell type="label" labelfor="6" />
          <cell type="field" id="6" name="dryadDOI" uitype="text" colspan="3" />
        </row>
        <row>
          <cell type="label" labelfor="7" />
          <cell type="field" id="7" name="traceFileName" uitype="text" colspan="3" />
          <cell type="label" labelfor="8" />
          <cell type="field" id="8" name="scoreFileName" uitype="text" colspan="3" />
        </row>
        <row>
          <cell type="label" labelfor="9" />
          <cell type="field" id="9" name="pcrPrimerName" uitype="text" />
          <cell type="label" labelfor="10" />
          <cell type="field" id="10" name="pcrForwardPrimerCode" uitype="text" />
          <cell type="label" labelfor="11" />
          <cell type="field" id="11" name="pcrReversePrimerCode" uitype="text" />
        </row>
        <row>
          <cell type="label" labelfor="12" />
          <cell type="field" id="12" name="sequencePrimerName" uitype="text" />
          <cell type="label" labelfor="13" />
          <cell type="field" id="13" name="sequencePrimerCode" uitype="text" />
          <cell type="label" labelfor="16" />
          <cell type="field" id="16" name="readDirection" uitype="text" />
        </row>
        <row>
          <cell type="label" labelfor="14" />
          <cell type="field" id="14" name="remarks" uitype="textareabrief" rows="2" colspan="7" />
          <cell type="subview" id="attachments" viewname="ObjectAttachment" name="attachments" initialize="btn=true;icon=DNASequencingRunAttachment;align=right" />
        </row>
      </rows>
    </viewdef>
  </viewdefs>
</viewset>