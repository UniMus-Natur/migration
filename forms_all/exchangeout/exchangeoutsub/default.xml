<viewset name="common" source="disk" level="Common" file="common/common.views.xml">
  <views>
    <view name="ExchangeOutSub" class="edu.ku.brc.specify.datamodel.ExchangeOut" busrules="edu.ku.brc.specify.datamodel.busrules.ExchangeOutBusRules">
      <desc>Exchange Out sub form</desc>
      <altviews>
        <altview name="ExchangeOutSub View" viewdef="ExchangeOutSub" mode="view" default="true" />
        <altview name="ExchangeOutSub Edit" viewdef="ExchangeOutSub" mode="edit" />
      </altviews>
    </view>
  </views>
  <viewdefs>
    <viewdef type="form" name="ExchangeOutSub" class="edu.ku.brc.specify.datamodel.ExchangeOut" gettable="edu.ku.brc.af.ui.forms.DataGetterForObj" settable="edu.ku.brc.af.ui.forms.DataSetterForObj">
      <desc>ExchangeOut sub form.</desc>
      <columnDef>105px,2px,170px,5px,125px,2px,150px,5px,96px,2px,170px,0px,15px,p,p:g</columnDef>
      <columnDef os="lnx">115px,2px,185px,5px,150px,2px,165px,5px,101px,2px,185px,0px,15px,p,p:g</columnDef>
      <columnDef os="mac">130px,2px,204px,5px,170px,2px,183px,5px,126px,2px,203px,0px,15px,p,p:g</columnDef>
      <columnDef os="exp">p,2px,p:g(2),5px:g,p,2px,p:g(2),5px,p:g,2px,p:g(2),0px,p,p:g</columnDef>
      <rowDef auto="true" cell="p" sep="1dlu" />
      <rows>
        <row>
          <cell type="label" labelfor="1" />
          <cell type="field" id="1" name="exchangeOutNumber" uitype="formattedtext" />
          <cell type="label" labelfor="7" />
          <cell type="field" id="7" name="quantityExchanged" uitype="text" />
          <cell type="label" labelfor="9" />
          <cell type="field" id="9" name="exchangeDate" uitype="formattedtext" uifieldformatter="Date" default="Today" />
        </row>
        <row>
          <cell type="label" labelfor="3" />
          <cell type="field" id="3" name="agentSentTo" uitype="querycbx" initialize="name=Agent" colspan="3" />
        </row>
        <row>
          <cell type="label" labelfor="4" />
          <cell type="field" id="4" name="descriptionOfMaterial" uitype="text" colspan="9" />
        </row>
        <row>
          <cell type="subview" viewname="ExchangeOutPrep" id="10" name="exchangeOutPreps" defaulttype="table" colspan="13" rows="4" />
        </row>
      </rows>
    </viewdef>
  </viewdefs>
</viewset>