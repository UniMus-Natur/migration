<viewset name="Karplaner - standard" source="db" level="Discipline">
  <views>
    <view name="Exsiccata" class="edu.ku.brc.specify.datamodel.Exsiccata" resourcelabels="false" isexternal="true">
      <desc>Exsiccata form.</desc>
      <altviews>
        <altview name="Exsiccata View" viewdef="Exsiccata" mode="view" />
        <altview name="Exsiccata Edit" viewdef="Exsiccata" mode="edit" default="true" />
      </altviews>
    </view>
  </views>
  <viewdefs>
    <viewdef type="form" name="Exsiccata" class="edu.ku.brc.specify.datamodel.Exsiccata" gettable="edu.ku.brc.af.ui.forms.DataGetterForObj" settable="edu.ku.brc.af.ui.forms.DataSetterForObj">
      <desc>Form for ExsiccataItem</desc>
      <columnDef>p,2px,p,p:g</columnDef>
      <rowDef auto="true" sep="2px" cell="p" />
      <rows>
        <row>
          <cell type="label" labelfor="1" />
          <cell type="field" id="1" name="title" uitype="text" />
        </row>
        <row>
          <cell type="label" labelfor="referenceWork" />
          <cell type="field" id="referenceWork" uitype="querycbx" initialize="name=ReferenceWork" name="referenceWork" />
        </row>
      </rows>
    </viewdef>
  </viewdefs>
</viewset>