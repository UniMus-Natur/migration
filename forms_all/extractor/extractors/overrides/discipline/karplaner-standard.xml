<viewset name="Karplaner - standard" source="db" level="Discipline">
  <views>
    <view name="Extractors" class="edu.ku.brc.specify.datamodel.Extractor" busrules="edu.ku.brc.specify.datamodel.busrules.ExtractorBusRules">
      <desc>DNA SequencingRun</desc>
      <altviews>
        <altview name="Extractors Table View" viewdef="Extractors Table" mode="view" />
        <altview name="Extractors Table Edit" viewdef="Extractors Table" mode="edit" default="true" />
      </altviews>
    </view>
  </views>
  <viewdefs>
    <viewdef type="formtable" name="Extractors Table" class="edu.ku.brc.specify.datamodel.Extractor" gettable="edu.ku.brc.af.ui.forms.DataGetterForObj" settable="edu.ku.brc.af.ui.forms.DataSetterForObj">
      <desc>Extractors grid view for CollectingEvent form.</desc>
      <definition>PcrPersons</definition>
    </viewdef>
    <viewdef type="form" name="PcrPersons" class="edu.ku.brc.specify.datamodel.PcrPerson" gettable="edu.ku.brc.af.ui.forms.DataGetterForObj" settable="edu.ku.brc.af.ui.forms.DataSetterForObj">
      <desc>The PcrPerson form</desc>
      <enableRules />
      <columnDef>p,5dlu,p:g,5dlu,p</columnDef>
      <rowDef auto="true" cell="p" sep="2px" />
      <rows>
        <row>
          <cell type="label" labelfor="3" />
          <cell type="field" id="3" name="agent.lastName" uitype="text" colspan="3" />
        </row>
        <row>
          <cell type="label" labelfor="5" />
          <cell type="field" id="5" name="agent.firstName" uitype="text" colspan="3" />
        </row>
        <row>
          <cell type="label" labelfor="7" />
          <cell type="field" id="7" name="remarks" uitype="text" colspan="3" />
        </row>
      </rows>
    </viewdef>
  </viewdefs>
</viewset>