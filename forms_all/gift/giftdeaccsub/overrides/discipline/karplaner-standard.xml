<viewset name="Karplaner - standard" source="db" level="Discipline">
  <views>
    <view name="GiftDeaccSub" class="edu.ku.brc.specify.datamodel.Gift" busrules="edu.ku.brc.specify.datamodel.busrules.GiftBusRules">
      <desc>Gift sub form</desc>
      <altviews>
        <altview name="GiftDeaccSub View" viewdef="GiftDeaccSub" mode="view" default="true" />
      </altviews>
    </view>
  </views>
  <viewdefs>
    <viewdef type="form" name="GiftDeaccSub" class="edu.ku.brc.specify.datamodel.Gift" gettable="edu.ku.brc.af.ui.forms.DataGetterForObj" settable="edu.ku.brc.af.ui.forms.DataSetterForObj">
      <desc>Gift viewing form.</desc>
      <columnDef>105px,2px,130px,5px,60px,2px,100px,5px,100px,2px,141px,15px,155px,0px,10px,p:g</columnDef>
      <columnDef os="lnx">115px,2px,146px,5px,75px,2px,100px,5px,115px,2px,155px,15px,180px,0px,15px,p:g</columnDef>
      <columnDef os="mac">130px,2px,160px,5px,86px,2px,125px,5px,130px,2px,185px,10px,200px,0px,15px,p:g</columnDef>
      <columnDef os="exp">p,2px,min(p;150px),5px:g,p,2px,p:g(2),5px:g,p,2px,p:g(2),5px,p,0px,p,p:g</columnDef>
      <rowDef auto="true" cell="p" sep="1dlu" />
      <rows>
        <row>
          <cell type="label" labelfor="1" />
          <cell type="field" id="1" name="giftNumber" uitype="formattedtext" />
          <cell type="label" labelfor="3" />
          <cell type="field" id="3" name="giftDate" uitype="formattedtext" uifieldformatter="Date" default="today" />
        </row>
        <row>
          <cell type="subview" viewname="GiftDeaccItems" id="10" name="giftPreparations" defaulttype="table" colspan="13" rows="2" />
        </row>
      </rows>
    </viewdef>
  </viewdefs>
</viewset>