<viewset name="Karplaner - standard" source="db" level="Discipline">
  <views>
    <view name="GiftAgent" objtitle="Gift Agent" class="edu.ku.brc.specify.datamodel.GiftAgent">
      <desc>Subform within the Accession form.</desc>
      <altviews>
        <altview name="GiftAgent Table View" viewdef="GiftAgent Table" mode="view" />
        <altview name="GiftAgent Table Edit" viewdef="GiftAgent Table" mode="edit" />
        <altview name="GiftAgent View" viewdef="GiftAgent" mode="view" />
        <altview name="GiftAgent Edit" viewdef="GiftAgent" mode="edit" default="true" />
      </altviews>
    </view>
  </views>
  <viewdefs>
    <viewdef type="form" name="GiftAgent" class="edu.ku.brc.specify.datamodel.GiftAgent" gettable="edu.ku.brc.af.ui.forms.DataGetterForObj" settable="edu.ku.brc.af.ui.forms.DataSetterForObj">
      <desc>The gift form.</desc>
      <enableRules />
      <columnDef>105px,2px,250px,5px,90px,2px,126px,252px,p:g</columnDef>
      <columnDef os="lnx">115px,2px,230px,5px,70px,2px,155px,p:g</columnDef>
      <columnDef os="mac">130px,2px,215px,5px,80px,2px,165px,433px,p:g</columnDef>
      <columnDef os="exp">p,2px,p:g,5px:g,p,2px,p:g,p:g</columnDef>
      <rowDef auto="true" cell="p" sep="2px" />
      <rows>
        <row>
          <cell type="label" labelfor="1" />
          <cell type="field" id="1" name="agent" uitype="querycbx" initialize="name=Agent;title=Agent" />
          <cell type="label" labelfor="2" />
          <cell type="field" id="2" name="role" uitype="combobox" />
        </row>
        <row>
          <cell type="label" labelfor="5" />
          <cell type="field" id="5" name="remarks" uitype="textareabrief" rows="2" colspan="6" />
        </row>
      </rows>
    </viewdef>
    <viewdef type="formtable" name="GiftAgent Table" class="edu.ku.brc.specify.datamodel.GiftAgent" gettable="edu.ku.brc.af.ui.forms.DataGetterForObj" settable="edu.ku.brc.af.ui.forms.DataSetterForObj">
      <desc>Preparation subform table for Collection Object form.</desc>
      <definition>GiftAgent</definition>
    </viewdef>
  </viewdefs>
</viewset>