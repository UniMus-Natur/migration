    <viewdef type="formtable" name="GiftDeaccItems Table" class="edu.ku.brc.specify.datamodel.GiftPreparation" gettable="edu.ku.brc.af.ui.forms.DataGetterForObj" settable="edu.ku.brc.af.ui.forms.DataSetterForObj">
