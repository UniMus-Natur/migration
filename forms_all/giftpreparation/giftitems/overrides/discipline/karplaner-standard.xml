<viewset name="Karplaner - standard" source="db" level="Discipline">
  <views>
    <view name="GiftItems" class="edu.ku.brc.specify.datamodel.GiftPreparation" busrules="edu.ku.brc.specify.datamodel.busrules.GiftPreparationBusRules">
      <desc>Gift display form</desc>
      <altviews>
        <altview name="GiftItems Table View" viewdef="GiftItems Table" mode="view" />
        <altview name="GiftItems Table Edit" viewdef="GiftItems Table" mode="edit" />
        <altview name="GiftItems View" viewdef="GiftItems" mode="view" default="true" />
        <altview name="GiftItems Edit" viewdef="GiftItems" mode="edit" />
      </altviews>
    </view>
  </views>
  <viewdefs>
    <viewdef type="form" name="GiftItems" class="edu.ku.brc.specify.datamodel.GiftPreparation" gettable="edu.ku.brc.af.ui.forms.DataGetterForObj" settable="edu.ku.brc.af.ui.forms.DataSetterForObj">
      <desc>Gift viewing form.</desc>
      <columnDef>105px,2px,115px,5px,80px,2px,80px,5px,140px,2px,130px,5px,69px,2px,90px,0px,p:g</columnDef>
      <columnDef os="lnx">115px,2px,150px,5px,100px,2px,75px,5px,150px,2px,139px,5px,80px,2px,85px,0px,p:g</columnDef>
      <columnDef os="mac">130px,2px,160px,5px,96px,2px,100px,5px,160px,2px,170px,5px,90px,2px,103px,0px,p:g</columnDef>
      <columnDef os="exp">p,2px,p:g(2),5px:g,p,2px,p:g(2),5px:g,p,2px,p:g(2),5px:g,p,2px,p:g(2),0px</columnDef>
      <rowDef auto="true" cell="p" sep="2dlu" />
      <rows>
        <row>
          <cell type="label" labelfor="9" />
          <cell type="field" id="9" name="preparation.collectionObject.catalogNumber" uitype="text" readonly="true" />
          <cell type="label" labelfor="1" />
          <cell type="field" id="1" name="quantity" uitype="spinner" initialize="max=2000" />
          <cell type="label" labelfor="2" label="Preparation Type" />
          <cell type="field" id="2" name="preparation.prepType.name" uitype="dsptextfield" readonly="true" />
          <cell type="label" labelfor="5" />
          <cell type="field" id="5" name="preparation.countAmt" uitype="dsptextfield" />
        </row>
        <row>
          <cell type="label" labelfor="3" />
          <cell type="field" id="3" name="descriptionOfMaterial" uitype="text" colspan="14" />
        </row>
      </rows>
    </viewdef>
    <viewdef type="formtable" name="GiftItems Table" class="edu.ku.brc.specify.datamodel.GiftPreparation" gettable="edu.ku.brc.af.ui.forms.DataGetterForObj" settable="edu.ku.brc.af.ui.forms.DataSetterForObj">
      <desc>{Preparation subform table for Gift form.</desc>
      <definition>GiftItems</definition>
    </viewdef>
  </viewdefs>
</viewset>