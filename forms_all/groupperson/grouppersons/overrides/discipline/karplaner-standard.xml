<viewset name="Karplaner - standard" source="db" level="Discipline">
  <views>
    <view name="GroupPersons" class="edu.ku.brc.specify.datamodel.GroupPerson" busrules="edu.ku.brc.specify.datamodel.busrules.GroupPersonBusRules" resourcelabels="false">
      <desc>GroupPerson form.</desc>
      <altviews>
        <altview name="GroupPersons Table View" viewdef="GroupPersons Table" mode="view" />
        <altview name="GroupPersons Table Edit" viewdef="GroupPersons Table" mode="edit" />
      </altviews>
    </view>
  </views>
  <viewdefs>
    <viewdef type="form" name="GroupPersons" class="edu.ku.brc.specify.datamodel.GroupPerson" gettable="edu.ku.brc.af.ui.forms.DataGetterForObj" settable="edu.ku.brc.af.ui.forms.DataSetterForObj">
      <desc>The Group Person form.</desc>
      <enableRules />
      <columnDef>60px,2px,p:g,2px</columnDef>
      <rowDef auto="true" cell="p" sep="2px" />
      <rows>
        <row>
          <cell type="label" labelfor="1" />
          <cell type="field" id="1" name="member" uitype="querycbx" initialize="name=Agent;title=Agent" />
        </row>
        <row>
          <cell type="label" labelfor="3" />
          <cell type="field" id="3" name="remarks" uitype="textareabrief" rows="2" colspan="2" />
        </row>
      </rows>
    </viewdef>
    <viewdef name="GroupPersons Table" type="formtable" class="edu.ku.brc.specify.datamodel.GroupPerson" gettable="edu.ku.brc.af.ui.forms.DataGetterForObj" settable="edu.ku.brc.af.ui.forms.DataSetterForObj">
      <desc>GroupPerson subform table for Agent form.</desc>
      <definition>GroupPersons</definition>
    </viewdef>
  </viewdefs>
</viewset>