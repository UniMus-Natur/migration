<viewset name="Global" source="disk" level="Backstop" file="backstop/global.views.xml">
  <views>
    <view name="Journal" class="edu.ku.brc.specify.datamodel.Journal" resourcelabels="false">
      <desc>The Journal Form.</desc>
      <altviews>
        <altview name="Journal View" viewdef="Journal" mode="view" validated="false" default="true" />
        <altview name="Journal Edit" viewdef="Journal" mode="edit" validated="true" />
      </altviews>
    </view>
  </views>
  <viewdefs>
    <viewdef type="form" name="Journal" class="edu.ku.brc.specify.datamodel.Journal" gettable="edu.ku.brc.af.ui.forms.DataGetterForObj" settable="edu.ku.brc.af.ui.forms.DataSetterForObj">
      <desc>The Journal form - unknown use in schema</desc>
      <columnDef>100px,2px,473px,5px,120px,2px,125px,p:g</columnDef>
      <columnDef os="lnx">115px,2px,460px,5px,150px,2px,183px,p:g</columnDef>
      <columnDef os="mac">130px,2px,518px,5px,180px,2px,195px,p:g</columnDef>
      <columnDef os="exp">p,2px,p:g(4),5px:g,p,2px,p:g(2)</columnDef>
      <rowDef auto="true" cell="p" sep="2dlu" />
      <rows>
        <row>
          <cell type="label" labelfor="1" />
          <cell type="field" id="1" name="journalName" uitype="text" />
          <cell type="label" labelfor="2" />
          <cell type="field" id="2" name="journalAbbreviation" uitype="text" />
        </row>
      </rows>
    </viewdef>
  </viewdefs>
</viewset>