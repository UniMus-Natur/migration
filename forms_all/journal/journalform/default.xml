<viewset name="Global" source="disk" level="Backstop" file="backstop/global.views.xml">
  <views>
    <view name="JournalForm" class="edu.ku.brc.specify.datamodel.Journal" isinternal="false" resourcelabels="false">
      <desc>The Journal Form.</desc>
      <altviews>
        <altview name="JournalForm View" viewdef="JournalForm" mode="view" validated="false" default="true" />
        <altview name="JournalForm Edit" viewdef="JournalForm" mode="edit" validated="true" />
      </altviews>
    </view>
  </views>
  <viewdefs>
    <viewdef type="form" name="JournalForm" class="edu.ku.brc.specify.datamodel.Journal" gettable="edu.ku.brc.af.ui.forms.DataGetterForObj" settable="edu.ku.brc.af.ui.forms.DataSetterForObj">
      <desc>The Journal form</desc>
      <columnDef>100px,2px,473px,5px,120px,2px,125px,15px,p:g</columnDef>
      <columnDef os="lnx">115px,2px,460px,5px,150px,2px,183px,15px,p:g</columnDef>
      <columnDef os="mac">130px,2px,518px,5px,180px,2px,195px,15px,p:g</columnDef>
      <columnDef os="exp">p,2px,p:g(4),5px:g,p,2px,p:g(2),p,p:g</columnDef>
      <rowDef auto="true" cell="p" sep="2dlu" />
      <rows>
        <row>
          <cell type="label" labelfor="1" />
          <cell type="field" id="1" name="journalName" uitype="text" />
          <cell type="label" labelfor="2" />
          <cell type="field" id="2" name="journalAbbreviation" uitype="text" />
        </row>
        <row>
          <cell type="subview" viewname="ReferenceWorkSub" id="3" name="referenceWorks" colspan="8" initialize="addsearch=true" />
        </row>
        <row>
          <cell type="label" labelfor="guid" />
          <cell type="field" id="guid" name="guid" uitype="text" readonly="true" />
        </row>
      </rows>
    </viewdef>
  </viewdefs>
</viewset>