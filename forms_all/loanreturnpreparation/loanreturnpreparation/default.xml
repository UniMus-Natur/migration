<viewset name="common" source="disk" level="Common" file="common/common.views.xml">
  <views>
    <view name="LoanReturnPreparation" class="edu.ku.brc.specify.datamodel.LoanReturnPreparation" busrules="edu.ku.brc.specify.datamodel.busrules.LoanReturnPreparationBusRules">
      <desc>LoanReturnPreparation display form</desc>
      <altviews>
        <altview name="LoanReturnPreparation View" viewdef="LoanReturnPreparation" mode="view" default="true" />
        <altview name="LoanReturnPreparation Edit" viewdef="LoanReturnPreparation" mode="edit" />
      </altviews>
    </view>
  </views>
  <viewdefs>
    <viewdef type="form" name="LoanReturnPreparation" class="edu.ku.brc.specify.datamodel.LoanReturnPreparation" gettable="edu.ku.brc.af.ui.forms.DataGetterForObj" settable="edu.ku.brc.af.ui.forms.DataSetterForObj">
      <desc>LoanReturnPreparation viewing form.</desc>
      <columnDef>102px,2px,50px,5px,110px,2px,50px,0px:g,p:g</columnDef>
      <columnDef os="lnx">120px,2px,80px,5px,120px,2px,80px,0px:g,p:g</columnDef>
      <columnDef os="mac">130px,2px,100px,5px,150px,2px,100px,0px:g,p:g</columnDef>
      <columnDef os="exp">p,2px,p:g(2),5px,p,2px,p:g(2),0px</columnDef>
      <rowDef auto="true" cell="p" sep="1dlu" />
      <rows>
        <row>
          <cell type="label" labelfor="1" />
          <cell type="field" id="1" name="receivedBy" uitype="querycbx" initialize="name=Agent" colspan="5" />
        </row>
        <row>
          <cell type="label" labelfor="2" />
          <cell type="field" id="2" name="returnedDate" uitype="formattedtext" uifieldformatter="Date" default="today" colspan="3" />
        </row>
        <row>
          <cell type="label" labelfor="3" />
          <cell type="field" id="3" name="quantityReturned" uitype="spinner" initialize="max=5000; min=0" />
          <cell type="label" labelfor="5" />
          <cell type="field" id="5" name="quantityResolved" uitype="spinner" initialize="max=5000; min=0" />
        </row>
        <row>
          <cell type="label" labelfor="4" />
          <cell type="field" id="4" name="remarks" uitype="textareabrief" colspan="6" rows="2" />
        </row>
      </rows>
    </viewdef>
  </viewdefs>
</viewset>