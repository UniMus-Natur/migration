<viewset name="SystemSetup" source="disk" level="Backstop" file="backstop/system.views.xml">
  <views>
    <view name="PickListItem" class="edu.ku.brc.specify.datamodel.PickListItem" resourcelabels="false">
      <desc>The PickListItem form.</desc>
      <altviews>
        <altview name="PickListItem View" viewdef="PickListItem" mode="view" validated="false" />
        <altview name="PickListItem Edit" viewdef="PickListItem" mode="edit" validated="true" default="true" />
      </altviews>
    </view>
  </views>
  <viewdefs>
    <viewdef name="PickListItem" class="edu.ku.brc.specify.datamodel.PickListItem" type="form" gettable="edu.ku.brc.af.ui.forms.DataGetterForObj" settable="edu.ku.brc.af.ui.forms.DataSetterForObj">
      <desc>PickListItem</desc>
      <enableRules />
      <columnDef>30px,2px,200px,p:g</columnDef>
      <rowDef auto="true" cell="p" sep="2dlu" />
      <rows>
        <row>
          <cell type="label" labelfor="title" />
          <cell type="field" id="title" name="title" uitype="text" isrequired="true" />
        </row>
        <row>
          <cell type="label" labelfor="value" />
          <cell type="field" id="value" name="value" label="Value" uitype="text" isrequired="true" />
        </row>
      </rows>
    </viewdef>
  </viewdefs>
</viewset>