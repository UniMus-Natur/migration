<viewset name="Karplaner - standard" source="db" level="Discipline">
  <views>
    <view name="Preparation" class="edu.ku.brc.specify.datamodel.Preparation" busrules="edu.ku.brc.specify.datamodel.busrules.PreparationBusRules" resourcelabels="false">
      <desc>Subform within the Preparation form.</desc>
      <altviews>
        <altview name="Preparation Table View" viewdef="Preparation Table" mode="view" />
        <altview name="Preparation Table Edit" viewdef="Preparation Table" mode="edit" />
        <altview name="Preparation View" viewdef="Preparation" mode="view" />
        <altview name="Preparation Edit" viewdef="Preparation" mode="edit" default="true" />
      </altviews>
    </view>
  </views>
  <viewdefs>
    <viewdef type="form" name="Preparation" class="edu.ku.brc.specify.datamodel.Preparation" gettable="edu.ku.brc.af.ui.forms.DataGetterForObj" settable="edu.ku.brc.af.ui.forms.DataSetterForObj" useresourcelabels="true">
      <desc>Preparation for Collection Object form.</desc>
      <enableRules />
      <columnDef>100px,2px,195px,5px,91px,2px,60px,5px,83px,2px,60px,5px,85px,2px,123px,2px,70px,p:g</columnDef>
      <columnDef os="lnx">115px,2px,200px,5px,110px,2px,67px,5px,82px,2px,67px,5px,100px,2px,126px,2px,75px,p:g</columnDef>
      <columnDef os="mac">130px,2px,215px,5px,110px,2px,80px,5px,93px,2px,80px,5px,105px,2px,174px,2px,70px,p:g</columnDef>
      <columnDef os="exp">p,2px,p:g(2),5px:g,p,2px,p:g,5px:g,p,2px,p:g,5px:g,p,2px,p:g,10px,p:g</columnDef>
      <rowDef auto="true" cell="p" sep="2dlu" />
      <rows>
        <row>
          <cell type="label" labelfor="7" />
          <cell type="field" id="7" name="prepType" uitype="combobox" picklist="PrepType" />
          <cell type="label" labelfor="3" />
          <cell type="field" id="3" name="countAmt" uitype="text" initialize="min=0" />
          <cell type="label" label="Current Count:" initialize="align=right" />
          <cell type="field" id="ti" name="actualCountAmt" uitype="text" readonly="true" />
          <cell type="field" id="isOnLoan" name="isOnLoan" uitype="checkbox" label="IS_ON_LOAN" readonly="true" />
          <cell type="command" id="ShowLoansBtn" name="ShowLoansBtn" label="SHOW_INTERACTIONS" ignore="true" />
          <cell type="subview" id="attachments" viewname="ObjectAttachment" name="preparationAttachments" initialize="align=right;btn=true;icon=PreparationAttachment" />
        </row>
        <row>
          <cell type="label" labelfor="2" />
          <cell type="field" id="2" name="preparedByAgent" uitype="querycbx" initialize="name=Agent" />
          <cell type="label" labelfor="1" />
          <cell type="field" id="1" uitype="plugin" name="this" initialize="name=PartialDateUI;df=preparedDate;tp=preparedDatePrecision" uifieldformatter="Date" colspan="5" />
          <cell type="label" labelfor="4" />
          <cell type="field" id="4" name="storage" uitype="querycbx" initialize="name=Storage" colspan="3" />
        </row>
      </rows>
    </viewdef>
    <viewdef type="formtable" name="Preparation Table" class="edu.ku.brc.specify.datamodel.Preparation" gettable="edu.ku.brc.af.ui.forms.DataGetterForObj" settable="edu.ku.brc.af.ui.forms.DataSetterForObj">
      <desc>Preparation subform table for Collection Object form.</desc>
      <definition>Preparation</definition>
    </viewdef>
  </viewdefs>
</viewset>