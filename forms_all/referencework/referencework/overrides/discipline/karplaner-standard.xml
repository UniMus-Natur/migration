<viewset name="Karplaner - standard" source="db" level="Discipline">
  <views>
    <view name="ReferenceWork" class="edu.ku.brc.specify.datamodel.ReferenceWork" isinternal="false" resourcelabels="false">
      <desc>The ReferenceWork Form.</desc>
      <altviews>
        <altview name="ReferenceWork View" viewdef="ReferenceWork" mode="view" validated="false" default="true" />
        <altview name="ReferenceWork Edit" viewdef="ReferenceWork" mode="edit" validated="true" />
      </altviews>
    </view>
  </views>
  <viewdefs>
    <viewdef type="form" name="ReferenceWork" class="edu.ku.brc.specify.datamodel.ReferenceWork" gettable="edu.ku.brc.af.ui.forms.DataGetterForObj" settable="edu.ku.brc.af.ui.forms.DataSetterForObj">
      <desc>The ReferenceWork form</desc>
      <columnDef>100px,2px,170px,5px,90px,2px,150px,5px,140px,2px,161px,15px,p:g</columnDef>
      <columnDef os="lnx">115px,2px,176px,5px,100px,2px,175px,5px,160px,2px,175px,15px,p:g</columnDef>
      <columnDef os="mac">130px,2px,208px,5px,100px,2px,208px,5px,175px,2px,195px,15px,p:g</columnDef>
      <columnDef os="exp">p,2px,p:g(2),5px:g,p,2px,p:g(2),5px:g,p,2px,p:g(2),p,p:g</columnDef>
      <rowDef auto="true" cell="p" sep="2dlu" />
      <rows>
        <row>
          <cell type="label" labelfor="8" />
          <cell type="field" id="8" name="referenceWorkType" uitype="combobox" />
        </row>
        <row>
          <cell type="label" labelfor="1" />
          <cell type="field" id="1" name="title" uitype="text" colspan="9" />
        </row>
        <row>
          <cell type="label" labelfor="2" />
          <cell type="field" id="2" name="publisher" uitype="text" colspan="5" />
          <cell type="label" labelfor="3" />
          <cell type="field" id="3" name="placeOfPublication" uitype="text" />
        </row>
        <row>
          <cell type="label" labelfor="4" />
          <cell type="field" id="4" name="workDate" uitype="text" />
          <cell type="label" labelfor="5" />
          <cell type="field" id="5" name="volume" uitype="text" />
          <cell type="label" labelfor="6" />
          <cell type="field" id="6" name="pages" uitype="text" />
        </row>
        <row>
          <cell type="label" labelfor="18" />
          <cell type="field" id="18" name="journal" uitype="querycbx" initialize="name=Journal;title=Journal" colspan="5" />
          <cell type="label" labelfor="7" />
          <cell type="field" id="7" name="libraryNumber" uitype="text" />
        </row>
        <row>
          <cell type="subview" viewname="Authors" id="10" name="authors" initialize="name=Agent" colspan="12" rows="3" />
        </row>
        <row>
          <cell type="subview" id="attachments" viewname="ObjectAttachment" name="referenceWorkAttachments" colspan="6" initialize="btn=true;icon=ReferenceWorkAttachment" />
        </row>
        <row>
          <cell type="label" labelfor="guid" />
          <cell type="field" id="guid" name="guid" uitype="text" colspan="5" readonly="true" />
        </row>
      </rows>
    </viewdef>
  </viewdefs>
</viewset>