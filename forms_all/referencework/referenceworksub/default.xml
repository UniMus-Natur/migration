<viewset name="Global" source="disk" level="Backstop" file="backstop/global.views.xml">
  <views>
    <view name="ReferenceWorkSub" class="edu.ku.brc.specify.datamodel.ReferenceWork" resourcelabels="false">
      <desc>The ReferenceWork SubForm.</desc>
      <altviews>
        <altview name="ReferenceWorkSub View" viewdef="ReferenceWorkSub" mode="view" default="true" />
        <altview name="ReferenceWorkSub Edit" viewdef="ReferenceWorkSub" mode="edit" />
      </altviews>
    </view>
  </views>
  <viewdefs>
    <viewdef type="form" name="ReferenceWorkSub" class="edu.ku.brc.specify.datamodel.ReferenceWork" gettable="edu.ku.brc.af.ui.forms.DataGetterForObj" settable="edu.ku.brc.af.ui.forms.DataSetterForObj">
      <desc>The ReferenceWork form</desc>
      <columnDef>100px,2px,170px,5px,90px,2px,150px,5px,140px,2px,161px</columnDef>
      <columnDef os="lnx">115px,2px,186px,5px,90px,2px,165px,5px,165px,2px,180px,p:g</columnDef>
      <columnDef os="mac">130px,2px,203px,5px,100px,2px,203px,5px,185px,2px,195px,p:g</columnDef>
      <columnDef os="exp">p,2px,p:g(2),5px:g,p,2px,p:g(2),5px:g,p,2px,p:g(2)</columnDef>
      <rowDef auto="true" cell="p" sep="2dlu" />
      <rows>
        <row>
          <cell type="label" labelfor="8" />
          <cell type="field" id="8" name="referenceWorkType" uitype="combobox" />
        </row>
        <row>
          <cell type="label" labelfor="1" />
          <cell type="field" id="1" name="title" uitype="text" colspan="9" />
        </row>
        <row>
          <cell type="label" labelfor="2" />
          <cell type="field" id="2" name="publisher" uitype="text" colspan="5" />
          <cell type="label" labelfor="3" />
          <cell type="field" id="3" name="placeOfPublication" uitype="text" />
        </row>
        <row>
          <cell type="label" labelfor="4" />
          <cell type="field" id="4" name="workDate" uitype="text" />
          <cell type="label" labelfor="5" />
          <cell type="field" id="5" name="volume" uitype="text" />
          <cell type="label" labelfor="6" />
          <cell type="field" id="6" name="pages" uitype="text" />
        </row>
      </rows>
    </viewdef>
  </viewdefs>
</viewset>