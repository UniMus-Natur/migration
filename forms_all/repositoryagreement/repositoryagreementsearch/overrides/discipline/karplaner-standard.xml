<viewset name="Karplaner - standard" source="db" level="Discipline">
  <views>
    <view name="RepositoryAgreementSearch" class="edu.ku.brc.specify.datamodel.RepositoryAgreement" usedefbusrule="false" resourcelabels="false">
      <desc>The RepositoryAgreement Search Form</desc>
      <altviews>
        <altview name="RepositoryAgreementSearch" viewdef="RepositoryAgreementSearch" mode="edit" validated="true" default="true" />
      </altviews>
    </view>
  </views>
  <viewdefs>
    <viewdef type="form" name="RepositoryAgreementSearch" class="edu.ku.brc.specify.datamodel.RepositoryAgreement" gettable="edu.ku.brc.af.ui.forms.DataGetterForHashMap" settable="edu.ku.brc.af.ui.forms.DataSetterForHashMap">
      <desc>The RepositoryAgreement Search Form</desc>
      <enableRules />
      <columnDef>p,3dlu,p</columnDef>
      <rowDef>p,2dlu,p,2dlu,p</rowDef>
      <rows>
        <row>
          <cell type="label" labelfor="1" />
          <cell type="field" id="1" name="RepositoryAgreementNumber" isrequired="false" uitype="text" />
        </row>
        <row>
          <cell type="label" labelfor="2" />
          <cell type="field" id="2" name="StartDate" isrequired="false" uitype="formattedtext" uifieldformatter="SearchDate" />
        </row>
      </rows>
    </viewdef>
  </viewdefs>
</viewset>