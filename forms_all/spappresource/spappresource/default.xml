<viewset name="SystemSetup" source="disk" level="Backstop" file="backstop/system.views.xml">
  <views>
    <view name="SpAppResource" objtitle="SpAppResource" class="edu.ku.brc.specify.datamodel.SpAppResource">
      <altviews>
        <altview name="SpAppResource View" viewdef="SpAppResource" mode="view" validated="false" />
        <altview name="SpAppResource Edit" viewdef="SpAppResource" mode="edit" default="true" validated="false" />
      </altviews>
    </view>
  </views>
  <viewdefs>
    <viewdef name="SpAppResource" class="edu.ku.brc.specify.datamodel.SpAppResource" type="form" gettable="edu.ku.brc.af.ui.forms.DataGetterForObj" settable="edu.ku.brc.af.ui.forms.DataSetterForObj">
      <desc>The SpAppResource Table</desc>
      <enableRules />
      <columnDef>20px,2px,100px,2px,20px,2px,50px,2px,p:g</columnDef>
      <rowDef auto="true" cell="p" sep="2px" />
      <rows>
        <row>
          <cell type="label" labelfor="name" />
          <cell type="field" id="name" name="name" uitype="text" />
          <cell type="label" labelfor="mimeType" />
          <cell type="field" id="mimeType" name="MimeType" uitype="combobox" />
        </row>
        <row>
          <cell type="label" labelfor="md" />
          <cell type="field" id="md" name="metadata" uitype="text" />
          <cell type="label" labelfor="timestampCreated" />
          <cell type="field" id="timestampCreated" name="timestampCreated" uitype="text" readonly="true" />
        </row>
        <row>
          <cell type="label" labelfor="desc" />
          <cell type="field" id="desc" name="description" uitype="text" />
          <cell type="label" labelfor="version" />
          <cell type="field" id="version" name="version" uitype="text" readonly="true" />
        </row>
        <row>
          <cell type="panel" colspan="7" coldef="20px,2px,100px,2px,20px,2px,50px,2px,p:g">
            <rows />
            <rows condition="mimeType=jrxml/report">
              <row>
                <cell type="label" label="Reports" />
                <cell type="subview" id="spReports" name="spReports" uitype="subview" readonly="true" initialize="btn=true" />
              </row>
            </rows>
            <rows condition="mimeType=jrxml/label">
              <row>
                <cell type="label" label="Labels" />
                <cell type="subview" id="spReports" name="spReports" uitype="subview" readonly="true" initialize="btn=true" />
              </row>
            </rows>
          </cell>
        </row>
      </rows>
    </viewdef>
  </viewdefs>
</viewset>