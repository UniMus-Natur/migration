<viewset name="Karplaner - standard" source="db" level="Discipline">
  <views>
    <view name="User" class="edu.ku.brc.specify.datamodel.SpecifyUser" busrules="edu.ku.brc.specify.datamodel.busrules.SpecifyUserBusRules" resourcelabels="false">
      <desc>User form.</desc>
      <altviews defaultmode="view">
        <altview name="User View" title="User" viewdef="User" mode="view" validated="false" />
        <altview name="User Edit" title="User" viewdef="User" mode="edit" validated="true" default="true" />
      </altviews>
    </view>
  </views>
  <viewdefs>
    <viewdef name="User" class="edu.ku.brc.specify.datamodel.SpecifyUser" type="form" gettable="edu.ku.brc.af.ui.forms.DataGetterForObj" settable="edu.ku.brc.af.ui.forms.DataSetterForObj">
      <desc>User Data Entry Form</desc>
      <columnDef>30px,2px,100px,2px,30px,2px,100px,2px,p:g</columnDef>
      <rowDef auto="true" cell="p" sep="2dlu" />
      <rows>
        <row>
          <cell type="label" labelfor="1" />
          <cell type="field" id="1" name="name" uitype="text" />
          <cell type="label" labelfor="3" />
          <cell type="field" id="3" name="password" uitype="text" />
        </row>
      </rows>
    </viewdef>
  </viewdefs>
</viewset>