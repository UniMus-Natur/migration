<viewset name="Karplaner - standard" source="db" level="Discipline">
  <views>
    <view name="UserGroup" class="edu.ku.brc.specify.datamodel.SpPrincipal" resourcelabels="false">
      <desc>User Group form.</desc>
      <altviews defaultmode="view">
        <altview name="User Group View" title="User Group" viewdef="User Group" mode="view" validated="false" />
        <altview name="User Group Edit" title="User Group" viewdef="User Group" mode="edit" validated="true" default="true" />
      </altviews>
    </view>
  </views>
  <viewdefs>
    <viewdef type="form" name="User Group" class="edu.ku.brc.specify.datamodel.SpPrincipal" gettable="edu.ku.brc.af.ui.forms.DataGetterForObj" settable="edu.ku.brc.af.ui.forms.DataSetterForObj">
      <desc>User Group Data Entry Form</desc>
      <columnDef>p,3dlu,p,p:g</columnDef>
      <rowDef auto="true" cell="p" sep="2dlu" />
      <rows>
        <row>
          <cell type="separator" label="User Group" colspan="4" />
        </row>
        <row>
          <cell type="label" labelfor="1" label="Name" />
          <cell type="field" id="1" name="name" uitype="text" cols="40" isrequired="true" />
        </row>
        <row>
          <cell type="label" labelfor="2" label="Remarks" />
          <cell type="field" id="2" name="remarks" uitype="textareabrief" cols="40" rows="2" colspan="2" />
        </row>
      </rows>
    </viewdef>
  </viewdefs>
</viewset>