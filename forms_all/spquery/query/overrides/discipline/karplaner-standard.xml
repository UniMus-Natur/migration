<viewset name="Karplaner - standard" source="db" level="Discipline">
  <views>
    <view name="Query" class="edu.ku.brc.specify.datamodel.SpQuery" resourcelabels="false">
      <desc>The Workbench Form.</desc>
      <altviews>
        <altview name="Query Edit" viewdef="Query" mode="edit" validated="true" default="true" />
      </altviews>
    </view>
  </views>
  <viewdefs>
    <viewdef name="Query" class="edu.ku.brc.specify.datamodel.SpQuery" type="form" gettable="edu.ku.brc.af.ui.forms.DataGetterForObj" settable="edu.ku.brc.af.ui.forms.DataSetterForObj">
      <desc>The Query form</desc>
      <columnDef>25px,2px,200px,2px,p:g</columnDef>
      <rowDef auto="true" cell="p" sep="2dlu" />
      <rows>
        <row>
          <cell type="label" labelfor="1" />
          <cell type="field" id="1" name="name" uitype="text" isrequired="true" />
        </row>
        <row>
          <cell type="label" label="Owner" />
          <cell type="field" id="owner" name="specifyUser" uitype="querycbx" isrequired="true" initialize="editbtn=false;newbtn=false" />
        </row>
      </rows>
    </viewdef>
  </viewdefs>
</viewset>