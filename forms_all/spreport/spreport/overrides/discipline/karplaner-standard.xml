<viewset name="Karplaner - standard" source="db" level="Discipline">
  <views>
    <view name="SpReport" objtitle="SpReport" class="edu.ku.brc.specify.datamodel.SpReport">
      <altviews>
        <altview name="SpReport View" viewdef="SpReport" mode="view" validated="false" />
        <altview name="SpReport Edit" viewdef="SpReport" mode="edit" default="true" validated="false" />
      </altviews>
    </view>
  </views>
  <viewdefs>
    <viewdef name="SpReport" class="edu.ku.brc.specify.datamodel.SpReport" type="form" gettable="edu.ku.brc.af.ui.forms.DataGetterForObj" settable="edu.ku.brc.af.ui.forms.DataSetterForObj">
      <desc>The SpReport Table</desc>
      <enableRules />
      <columnDef>p,2px,p,2px,p,2px,p,2px,p,2px,p,p:g</columnDef>
      <rowDef auto="true" cell="p" sep="2px" />
      <rows>
        <row>
          <cell type="label" labelfor="nm" />
          <cell type="field" id="nm" name="name" uitype="text" />
        </row>
        <row>
          <cell type="label" labelfor="q" />
          <cell type="field" id="q" name="query" uitype="querycbx" />
        </row>
        <row>
          <cell type="label" labelfor="aR" />
          <cell type="field" id="aR" name="appResource" uitype="querycbx" initialize="editbtn=false;newbtn=false;viewBtn=false" />
        </row>
      </rows>
    </viewdef>
  </viewdefs>
</viewset>