<viewset name="Karplaner - standard" source="db" level="Discipline">
  <views>
    <view name="SpSymbiotaInstance" class="edu.ku.brc.specify.datamodel.SpSymbiotaInstance" resourcelabels="false">
      <desc>Symbiota Instance Data Entry Form</desc>
      <altviews>
        <altview name="SymbiotaInstanceDataEntry" viewdef="SymbiotaInstanceDataEntry" mode="edit" validated="true" />
      </altviews>
    </view>
  </views>
  <viewdefs>
    <viewdef type="form" name="SymbiotaInstanceDataEntry" class="edu.ku.brc.specify.datamodel.SpSymbiotaInstance" gettable="edu.ku.brc.af.ui.forms.DataGetterForObj" settable="edu.ku.brc.af.ui.forms.DataSetterForObj">
      <desc>Symbiota Instance Data Entry Form</desc>
      <columnDef>p,3dlu,p,6dlu,p</columnDef>
      <rowDef auto="true" cell="p" sep="2px" />
      <rows>
        <row>
          <cell type="label" labelfor="1" label="Instance Name" />
          <cell type="field" id="1" name="instanceName" uitype="text" isrequired="true" />
        </row>
        <row>
          <cell type="label" labelfor="2" label="Symbiota Key" />
          <cell type="field" id="2" name="symbiotaKey" uitype="text" isrequired="true" />
        </row>
        <row>
          <cell type="label" labelfor="4" label="Description" />
          <cell type="field" id="4" name="description" uitype="text" />
        </row>
        <row>
          <cell type="label" labelfor="3" label="Remarks" />
          <cell type="field" id="3" name="remarks" uitype="textareabrief" rows="3" />
        </row>
      </rows>
    </viewdef>
  </viewdefs>
</viewset>