<viewset name="Global" source="disk" level="Backstop" file="backstop/global.views.xml">
  <views>
    <view name="StorageSubform" class="edu.ku.brc.specify.datamodel.Storage" busrules="edu.ku.brc.specify.datamodel.busrules.StorageBusRules" resourcelabels="false">
      <desc>Storage data entry form.</desc>
      <altviews>
        <altview name="Storage Children View" viewdef="StorageSubform" mode="view" />
      </altviews>
    </view>
  </views>
  <viewdefs>
    <viewdef name="StorageSubform" type="form" class="edu.ku.brc.specify.datamodel.Storage" gettable="edu.ku.brc.af.ui.forms.DataGetterForObj" settable="edu.ku.brc.af.ui.forms.DataSetterForObj">
      <desc>New Storage Node Form</desc>
      <enableRules />
      <columnDef>100px,2px,725px,0px,p:g</columnDef>
      <columnDef os="lnx">115px,2px,800px,0px,p:g</columnDef>
      <columnDef os="mac">130px,2px,900px,0px,p:g</columnDef>
      <columnDef os="exp">p,2px,p:g(2),0px</columnDef>
      <rowDef auto="true" cell="p" sep="2dlu" />
      <rows>
        <row>
          <cell type="label" labelfor="fullName" />
          <cell type="field" id="fullName" uitype="text" name="fullName" colspan="2" />
        </row>
      </rows>
    </viewdef>
  </viewdefs>
</viewset>