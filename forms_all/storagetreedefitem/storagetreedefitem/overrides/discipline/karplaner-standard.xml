<viewset name="Karplaner - standard" source="db" level="Discipline">
  <views>
    <view name="StorageTreeDefItem" class="edu.ku.brc.specify.datamodel.StorageTreeDefItem" resourcelabels="false">
      <desc>StorageTreeDefItem Form</desc>
      <altviews>
        <altview name="Tree Def Item Edit" viewdef="StorageTreeDefItem" mode="edit" validated="true" />
      </altviews>
    </view>
  </views>
  <viewdefs>
    <viewdef name="StorageTreeDefItem" class="edu.ku.brc.specify.datamodel.StorageTreeDefItem" type="form" gettable="edu.ku.brc.af.ui.forms.DataGetterForObj" settable="edu.ku.brc.af.ui.forms.DataSetterForObj">
      <desc>Storage Tree Definition Item Form</desc>
      <enableRules />
      <columnDef>p,px,p,2px,p:g</columnDef>
      <rowDef auto="true" cell="p" sep="2px" />
      <rows>
        <row>
          <cell type="label" labelfor="1" />
          <cell type="field" id="1" name="name" uitype="text" isrequired="true" />
        </row>
        <row>
          <cell type="label" labelfor="2" />
          <cell type="field" id="2" name="title" uitype="text" isrequired="true" />
        </row>
        <row>
          <cell type="label" labelfor="3" />
          <cell type="field" id="3" name="remarks" uitype="textareabrief" rows="2" />
        </row>
        <row>
          <cell type="label" label=" " />
          <cell type="field" id="4" uitype="checkbox" name="isInFullName" />
        </row>
        <row>
          <cell type="label" label=" " />
          <cell type="field" id="5" uitype="checkbox" name="isEnforced" />
        </row>
        <row>
          <cell type="label" labelfor="6" />
          <cell type="field" uitype="text" id="6" name="textBefore" />
        </row>
        <row>
          <cell type="label" labelfor="7" />
          <cell type="field" uitype="text" id="7" name="textAfter" />
        </row>
        <row>
          <cell type="label" labelfor="8" />
          <cell type="field" id="8" uitype="text" name="fullNameSeparator" default=" " />
        </row>
      </rows>
    </viewdef>
  </viewdefs>
</viewset>