<viewset name="Karplaner - standard" source="db" level="Discipline">
  <views>
    <view name="Workbench" class="edu.ku.brc.specify.datamodel.Workbench" resourcelabels="false">
      <desc>The Workbench Form.</desc>
      <altviews>
        <altview name="Workbench Edit" viewdef="Workbench" mode="edit" validated="true" default="true" />
      </altviews>
    </view>
  </views>
  <viewdefs>
    <viewdef type="form" name="Workbench" class="edu.ku.brc.specify.datamodel.Workbench" gettable="edu.ku.brc.af.ui.forms.DataGetterForObj" settable="edu.ku.brc.af.ui.forms.DataSetterForObj">
      <desc>The WorkbenchTemplate form</desc>
      <columnDef>p,2px,p:g</columnDef>
      <rowDef auto="true" cell="p" sep="2dlu" />
      <rows>
        <row>
          <cell type="label" labelfor="1" />
          <cell type="field" id="1" name="name" uitype="text" isrequired="true" cols="40" />
        </row>
        <row>
          <cell type="label" labelfor="4" />
          <cell type="field" id="4" name="remarks" uitype="textareabrief" rows="2" />
        </row>
        <row>
          <cell type="label" labelfor="3" />
          <cell type="field" id="3" name="workbenchTemplate.srcFilePath" uitype="dsptextfield" initialize="transparent=true" />
        </row>
      </rows>
    </viewdef>
  </viewdefs>
</viewset>