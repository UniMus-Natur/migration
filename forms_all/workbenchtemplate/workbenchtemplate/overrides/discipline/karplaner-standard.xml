<viewset name="Karplaner - standard" source="db" level="Discipline">
  <views>
    <view name="WorkbenchTemplate" class="edu.ku.brc.specify.datamodel.WorkbenchTemplate" resourcelabels="false">
      <desc>The WorkbenchTemplate Form.</desc>
      <altviews>
        <altview name="WorkbenchTemplate Edit" viewdef="WorkbenchTemplate" mode="edit" validated="true" default="true" />
      </altviews>
    </view>
  </views>
  <viewdefs>
    <viewdef type="form" name="WorkbenchTemplate" class="edu.ku.brc.specify.datamodel.WorkbenchTemplate" gettable="edu.ku.brc.af.ui.forms.DataGetterForObj" settable="edu.ku.brc.af.ui.forms.DataSetterForObj">
      <desc>The WorkbenchTemplate form</desc>
      <columnDef>p,2px,p:g</columnDef>
      <rowDef auto="true" cell="p" sep="2dlu" />
      <rows>
        <row>
          <cell type="label" labelfor="1" />
          <cell type="field" id="1" name="name" uitype="text" isrequired="true" />
        </row>
        <row>
          <cell type="label" labelfor="2" />
          <cell type="field" id="2" name="remarks" uitype="textareabrief" rows="2" />
        </row>
      </rows>
    </viewdef>
  </viewdefs>
</viewset>