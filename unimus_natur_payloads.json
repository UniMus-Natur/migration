[
    {
        "endpoint": "/api/setup/setup_database/",
        "description": "Initial setup: Creates Institution, first Division (Biology), first Discipline (Karplanter Moser), and first Collection (NHM).",
        "payload": {
            "institution": {
                "name": "UniMus:Natur",
                "issinglegeographytree": true
            },
            "storageTreeDef": {
                "name": "Storage Tree",
                "preload": false
            },
            "division": {
                "name": "Biology"
            },
            "discipline": {
                "name": "Karplanter Moser",
                "type": "botany"
            },
            "geographyTreeDef": {
                "name": "Geography",
                "preload": false
            },
            "taxonTreeDef": {
                "name": "Taxon",
                "preload": false
            },
            "collection": {
                "name": "NHM",
                "code": "NHM"
            },
            "specifyUser": {
                "username": "admin",
                "email": "admin@unimus.no",
                "password": "change-me",
                "first_name": "Admin",
                "last_name": "User"
            }
        }
    },
    {
